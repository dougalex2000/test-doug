# ==============================================================================
# Projeto DAVI — Variáveis de ambiente
#
# Copie este arquivo para `.env.local` e preencha os valores reais.
# NUNCA faça commit de `.env.local` (já está no .gitignore).
# Na Vercel, configure estas variáveis pelo dashboard ou `vercel env`.
# ==============================================================================

# ------------------------------------------------------------------------------
# Supabase (banco PostgreSQL + autenticação)
# Crie um projeto em https://supabase.com e copie os valores em
# Project Settings → API.
# ------------------------------------------------------------------------------

# URL do projeto Supabase. Prefixo NEXT_PUBLIC_ = exposta ao navegador (ok).
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (anon/publishable). Pode ir ao navegador: o RLS limita o acesso.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave service role — PODER TOTAL, ignora RLS.
# SOMENTE em código server-side (Route Handlers, Server Actions).
# NUNCA usar prefixo NEXT_PUBLIC_ nesta chave. NUNCA importar em Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# Conexão direta ao Postgres (para migrações via psql/CLI).
# Project Settings → Database → Connection string.
DATABASE_URL=

# ------------------------------------------------------------------------------
# Inteligência Artificial (futuro — relatórios e recomendações)
# Server-only: sem NEXT_PUBLIC_.
# ------------------------------------------------------------------------------
# AI_GATEWAY_API_KEY=
